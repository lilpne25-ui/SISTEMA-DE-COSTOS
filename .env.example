# Variable requerida para autorizar la eliminacion de ficha tecnica PDF.
# Define una contrasena robusta solo en tu archivo local .env (no versionado).
SISTEMA_COSTOS_PASSWORD=

# Backend de datos
SISTEMA_COSTOS_DB_BACKEND=pervasive

# Pervasive (solo si backend=pervasive)
SISTEMA_COSTOS_PERVASIVE_DSN=
SISTEMA_COSTOS_PERVASIVE_USER=
SISTEMA_COSTOS_PERVASIVE_PASSWORD=
